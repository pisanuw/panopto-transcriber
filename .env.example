# Copy this file to .env and fill in real values.
# .env is gitignored.

# --- Panopto -----------------------------------------------------------------
# Host for your institution's Panopto instance (no scheme, no trailing slash).
PANOPTO_HOST=uw.hosted.panopto.com
# yt-dlp reads your browser's cookies for SSO auth — no Panopto API access required.
# Supported: chrome | safari | firefox | brave | edge | chromium | opera | vivaldi
COOKIES_BROWSER=chrome
# Optional profile name (e.g. "Default", "Profile 1"). Blank = default profile.
COOKIES_PROFILE=

# --- Canvas ------------------------------------------------------------------
# Personal access token from Canvas (Profile -> Settings -> Approved Integrations).
# Used only by future course-discovery commands.
CANVAS_URL=https://canvas.uw.edu
CANVAS_TOKEN=

# --- Local paths -------------------------------------------------------------
DOWNLOAD_DIR=./downloads
TRANSCRIPT_DIR=./transcripts

# --- Transcription defaults --------------------------------------------------
# Backend: whisper-cpp | openai-whisper
TRANSCRIBER_BACKEND=whisper-cpp
# For whisper.cpp this is informational; for openai-whisper it's the model id.
TRANSCRIBER_MODEL=base.en
# Path to the whisper.cpp ggml-*.bin file
WHISPER_CPP_MODEL_PATH=./models/whisper/ggml-base.en.bin
# Binary name; `brew install whisper-cpp` puts `whisper-cli` on PATH
WHISPER_CPP_BIN=whisper-cli
